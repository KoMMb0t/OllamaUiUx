# ============================================================
#  Umgebungsvariablen – Kopiere diese Datei als .env
#  cp .env.example .env  (dann Werte eintragen)
# ============================================================

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Geheimer Schlüssel für Open WebUI Sessions (beliebiger langer String)
WEBUI_SECRET_KEY=mein-geheimer-schluessel-bitte-aendern

# Optional: Standard-Admin E-Mail für ersten Login
# WEBUI_ADMIN_EMAIL=deine@email.com
