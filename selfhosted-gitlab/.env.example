# ============================================================
#  GitLab Konfiguration
#  cp .env.example .env  → dann anpassen
# ============================================================

# Hostname oder IP deines Servers
# Für lokalen Test: localhost oder 192.168.x.x
# Für echten Server: deine-domain.at oder sub.domain.at
GITLAB_HOSTNAME=localhost

# Ports (ändern falls belegt)
GITLAB_HTTP_PORT=8929
GITLAB_HTTPS_PORT=8443
GITLAB_SSH_PORT=2222

# Zeitzone
GITLAB_TIMEZONE=Europe/Vienna
